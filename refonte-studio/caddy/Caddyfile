    email {$LETSENCRYPT_EMAIL:admin@luminaview.fr}
}

# -------------------------------------------------------------
# 1. STUDIO MANAGER (jac-photo.fr & luminaview.fr - Administration Privée)
# -------------------------------------------------------------
jac-photo.fr, www.jac-photo.fr {
    # API Express Backend & Fichiers Uploads (conserve le préfixe /api et /uploads)
    handle /api/* {
        reverse_proxy luminaview-backend:3000
    }
    handle /uploads/* {
        reverse_proxy luminaview-backend:3000
    }

    # Frontend Studio Manager
    handle {
        reverse_proxy luminaview-manager:80
    }
}

luminaview.fr, www.luminaview.fr {
    # API Express Backend & Fichiers Uploads (conserve le préfixe /api et /uploads)
    handle /api/* {
        reverse_proxy luminaview-backend:3000
    }
    handle /uploads/* {
        reverse_proxy luminaview-backend:3000
    }

    # Frontend Studio Manager
    handle {
        reverse_proxy luminaview-manager:80
    }
}

# -------------------------------------------------------------
# 2. ECOSYSTÈME PUBLIC HÉLIOSCOPE (*.helioscope.fr)
# -------------------------------------------------------------
*.helioscope.fr {
    # Routage /blog et /blog/* vers le conteneur Blog (nettoie le préfixe pour l'application SPA)
    handle_path /blog* {
        reverse_proxy luminaview-blog:80
    }

    # Routage /carnet et /carnet/* vers le conteneur Chambre Noire (nettoie le préfixe pour l'application SPA)
    handle_path /carnet* {
        reverse_proxy luminaview-chambrenoire:80
    }

    # Proxification API & Fichiers Uploadés pour l'accès public (conserve le préfixe)
    handle /api/* {
        reverse_proxy luminaview-backend:3000
    }
    handle /uploads/* {
        reverse_proxy luminaview-backend:3000
    }

    # Par défaut : Portfolio public de l'utilisateur (ex: jac.helioscope.fr)
    handle {
        reverse_proxy luminaview-portfolio:80
    }
}
