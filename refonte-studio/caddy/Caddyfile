{
    email {$LETSENCRYPT_EMAIL:admin@luminaview.fr}
    on_demand_tls {
        ask http://127.0.0.1:5555
    }
}

# Dummy endpoint for on_demand_tls ask
:5555 {
    respond 200
}

# -------------------------------------------------------------
# 1. STUDIO MANAGER (luminaview.fr - Administration Privée)
# -------------------------------------------------------------
luminaview.fr, www.luminaview.fr {
    # API Express Backend & Fichiers Uploads (conserve le préfixe /api et /uploads)
    handle /api/* {
        reverse_proxy luminaview-backend:3000
    }
    handle /uploads/* {
        reverse_proxy luminaview-backend:3000
    }

    # Frontend Studio Manager
    handle {
        reverse_proxy luminaview-manager:80
    }
}

# -------------------------------------------------------------
# 2. ECOSYSTÈME PUBLIC MULTI-UTILISATEURS DYNAMIQUE (*.helioscope.fr)
# -------------------------------------------------------------
https:// {
    tls {
        on_demand
    }

    # API & Uploads pour tout l'écosystème
    handle /api/* {
        reverse_proxy luminaview-backend:3000
    }
    handle /uploads/* {
        reverse_proxy luminaview-backend:3000
    }

    # Sous-domaine spécifique pour le BLOG
    @blog host *-blog.helioscope.fr
    handle @blog {
        reverse_proxy luminaview-blog:80
    }

    # Sous-domaine spécifique pour le CARNET
    @carnet host *-carnet.helioscope.fr
    handle @carnet {
        reverse_proxy luminaview-chambrenoire:80
    }

    # Par défaut : Portfolio (*.helioscope.fr ou helioscope.fr)
    @helioscope host *.helioscope.fr helioscope.fr
    handle @helioscope {
        reverse_proxy luminaview-portfolio:80
    }
}
