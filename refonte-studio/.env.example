# ==========================================
# ENVIRONNEMENT DE PRODUCTION LUMINAVIEW GEMINI (EXAMPLE)
# ==========================================
COMPOSE_FILE=docker-compose.prod.yml

# Variables MongoDB
MONGO_URI=mongodb://mongo:27017/luminaview_core

# Secrets de connexion
JWT_SECRET=change_this_jwt_secret
SESSION_SECRET=change_this_session_secret

# Limite d'upload des images (en MB)
MAX_FILE_SIZE_MB=100

# ==========================================
# CONFIGURATION EMAILS (SMTP BREVO)
# ==========================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Hélioscope <admin@lumina.fr>"
ADMIN_EMAIL=admin@lumina.fr

# ==========================================
# CONFIGURATION SSL / CADDY
# ==========================================
LETSENCRYPT_EMAIL=admin@lumina.fr
